{
  "name": "page-speed",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "lint": "eslint .",
    "postinstall": "nuxt prepare && simple-git-hooks",
    "test:e2e": "playwright test test/e2e",
    "test:e2e:update": "docker run --rm --network host -v $(pwd):/work/ -v /tmp/playwright-nm:/work/node_modules -w /work/ -it mcr.microsoft.com/playwright:v1.60.0-noble bash -c 'corepack enable && pnpm i && pnpm playwright test test/e2e --update-snapshots'"
  },
  "dependencies": {
    "@azure/identity": "^4.13.1",
    "@azure/storage-blob": "^12.32.0",
    "@neoconfetti/vue": "^2.2.1",
    "@nuxt/fonts": "^0.14.0",
    "@nuxtjs/html-validator": "^2.1.0",
    "@nuxtjs/plausible": "^3.0.2",
    "@takumi-rs/core": "^1.7.0",
    "@unocss/nuxt": "^66.7.0",
    "defu": "^6.1.7",
    "nitropack": "^2.13.4",
    "nuxt": "^4.4.7",
    "nuxt-og-image": "^6.5.2",
    "scule": "^1.3.0",
    "ufo": "^1.6.4",
    "vue": "^3.5.35"
  },
  "devDependencies": {
    "@actions/core": "2.0.3",
    "@actions/http-client": "4.0.1",
    "@nuxt/eslint": "1.15.2",
    "@nuxt/test-utils": "4.0.3",
    "@playwright/test": "1.60.0",
    "eslint": "10.4.1",
    "mock-driver": "link:./test/mock-driver",
    "nano-staged": "1.0.2",
    "simple-git-hooks": "2.13.1",
    "typescript": "6.0.3",
    "unstorage": "1.17.5"
  },
  "simple-git-hooks": {
    "pre-commit": "npx nano-staged"
  },
  "packageManager": "pnpm@11.5.2",
  "nano-staged": {
    "*.{js,ts,mjs,cjs,json,.*rc}": [
      "npx eslint --fix"
    ]
  }
}
